{
  "name": "roojerry",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "/opt/homebrew/bin/hugo server -D",
    "build": "/opt/homebrew/bin/hugo --minify && npx purgecss --config purgecss.config.js && npx terser public/js/bg-field.js -o public/js/bg-field.js -c -m",
    "build:check": "/opt/homebrew/bin/hugo --minify --renderToMemory",
    "preview": "/opt/homebrew/bin/hugo server --disableFastRender",
    "assets": "node scripts/assets.mjs process",
    "assets:check": "node scripts/assets.mjs check",
    "assets:clean": "node scripts/assets.mjs clean",
    "clean": "rm -rf public/",
    "env": "/opt/homebrew/bin/hugo env",
    "test": "node tests/runner.js",
    "test:visual": "node tests/visual/runner.js",
    "test:watch": "node --watch tests/e2e/achievements.test.js",
    "test:update": "UPDATE_SNAPSHOTS=1 node tests/visual/runner.js"
  },
  "devDependencies": {
    "puppeteer": "^24.0.0",
    "purgecss": "^8.0.0",
    "sharp": "^0.34.5",
    "terser": "^5.0.0"
  }
}
